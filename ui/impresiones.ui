  <property name="styleSheet">
   <string notr="true">/* ==========================================================================
   TEMA PREMIUM NEGRO &amp; DORADO
   ========================================================================== */

QWidget {
    background-color: #121212;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 14px;
    color: #E8D9A8;
}

/* ==========================================================================
   ETIQUETAS / QLABEL
   ========================================================================== */

QLabel {
    background-color: transparent;
    color: #D4AF37;
    font-weight: 500;
    padding: 2px;
}

/* Títulos */
QLabel#sectionTitle {
    font-size: 20px;
    font-weight: bold;
    color: #F5D76E;
    padding-bottom: 10px;
}

/* ==========================================================================
   CAMPOS DE TEXTO / QLINEEDIT
   ========================================================================== */

QLineEdit {
    background-color: #1E1E1E;
    color: #F5E6B3;
    border: 1px solid #6E5A1E;
    border-radius: 8px;
    padding: 8px 12px;
    selection-background-color: #D4AF37;
    selection-color: #121212;
}

QLineEdit:focus {
    border: 2px solid #D4AF37;
    background-color: #252525;
}

QLineEdit:disabled {
    background-color: #1A1A1A;
    color: #666666;
    border: 1px solid #333333;
}

/* ==========================================================================
   BOTONES / QPUSHBUTTON
   ========================================================================== */

QPushButton {
    background-color: #D4AF37;
    color: #121212;
    font-weight: bold;
    border: 1px solid #F5D76E;
    border-radius: 8px;
    padding: 8px 18px;
}

QPushButton:hover {
    background-color: #E6C65C;
    border: 1px solid #FFD700;
}

QPushButton:pressed {
    background-color: #B8941F;
    padding-top: 9px;
    padding-left: 19px;
}

QPushButton:disabled {
    background-color: #3A3A3A;
    color: #777777;
    border: 1px solid #555555;
}

/* ==========================================================================
   COMBOBOX
   ========================================================================== */

QComboBox {
    background-color: #1E1E1E;
    color: #F5E6B3;
    border: 1px solid #6E5A1E;
    border-radius: 8px;
    padding: 6px 10px;
}

QComboBox:hover {
    border: 1px solid #D4AF37;
}

QComboBox::drop-down {
    border: none;
}

/* ==========================================================================
   TABLAS / QTABLEWIDGET
   ========================================================================== */

QTableWidget {
    background-color: #1A1A1A;
    color: #F5E6B3;
    gridline-color: #444444;
    border: 1px solid #6E5A1E;
    border-radius: 6px;
}

QHeaderView::section {
    background-color: #D4AF37;
    color: #121212;
    padding: 6px;
    border: none;
    font-weight: bold;
}

/* ==========================================================================
   SCROLLBAR
   ========================================================================== */

QScrollBar:vertical {
    background: #1A1A1A;
    width: 12px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #D4AF37;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #F5D76E;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

/* ==========================================================================
   GROUPBOX
   ========================================================================== */

QGroupBox {
    color: #D4AF37;
    border: 1px solid #6E5A1E;
    border-radius: 10px;
    margin-top: 12px;
    padding-top: 12px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
}</string>
